# =============================================================================
# Copy this file to `.env` at the project root (same folder as README.md).
# Fill in secrets only; leave defaults or leave blank where noted.
# Never commit `.env` (it is gitignored).
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED — Webapp chat API (Gemini answers)
# -----------------------------------------------------------------------------
# Google AI API key for streamed chat answers (Scripts/rag_chat_service.py).
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Chat model for webapp + optional Ragas judge (minimal/full metrics).
# Default in code if unset: gemini-2.0-flash
GEMINI_MODEL=gemini-2.0-flash


# -----------------------------------------------------------------------------
# REQUIRED — Hugging Face (only if you download MultiEURLEX locally)
# -----------------------------------------------------------------------------
# Used by: python -m Scripts.data_extraction_load
# Leave empty if Data/train.jsonl already exists.
HF_TOKEN=


# -----------------------------------------------------------------------------
# Webapp — RAG retrieval (dedup eval winner; Ollama embeds queries)
# -----------------------------------------------------------------------------
# Chunking strategy id (must match built dedup Chroma + chunks JSONL).
RAG_CHUNK_STRATEGY=len_500_o50

# Retriever id (hybrid + cross-encoder rerank).
RAG_RETRIEVER=hyb_fill_dense_then_bm25_ce_r50

# Final chunks passed to Gemini after rerank.
RAG_FINAL_K=20

# First-stage candidate pool size before rerank.
RAG_CANDIDATE_K=100

# Drop sources below this **normalized** rerank score (0–1 within each query batch).
RAG_MIN_RERANK_SCORE=0.3

# Multi-turn chat: max prior messages sent to Gemini (user + assistant pairs).
RAG_HISTORY_MAX_MESSAGES=20
RAG_HISTORY_MSG_MAX_CHARS=4000

# FastAPI CORS: comma-separated browser origins (Vite dev server).
CORS_ORIGINS=http://localhost:5173


# -----------------------------------------------------------------------------
# Cross-encoder reranker (webapp retrieval + eval scripts)
# -----------------------------------------------------------------------------
# Hugging Face model id. Lighter alternatives:
#   BAAI/bge-reranker-base
#   cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_MODEL=BAAI/bge-reranker-v2-m3

# Device: leave empty = try CUDA, fall back to CPU on OOM.
# Or set explicitly: cpu | cuda | cuda:0
RERANK_DEVICE=

# Max characters per passage sent to reranker.
RERANK_PASSAGE_MAX_CHARS=8000

# CrossEncoder.predict batch size (lower = less VRAM).
RERANK_PREDICT_BATCH_SIZE=32

# First-stage pool for grid eval retrievers *_ce_r50 (default 50).
# Webapp uses RAG_CANDIDATE_K instead; this affects run_grid_eval / top10 evals.
RETRIEVAL_CANDIDATE_K=50


# -----------------------------------------------------------------------------
# Gemini — Ragas judge only (python -m Scripts.eval.llm_triad.judge_rag_triad)
# -----------------------------------------------------------------------------
# Embedding model for Ragas when --provider gemini (not used by webapp chat).
# Default in code if unset: gemini-embedding-001
GEMINI_EMBEDDING_MODEL=gemini-embedding-001


# -----------------------------------------------------------------------------
# Eval pipeline (optional — batch scripts, not the webapp)
# -----------------------------------------------------------------------------
# Set to 1 after each chunk strategy in grid eval to free GPU memory.
EVAL_CUDA_EMPTY_CACHE=

# Dedup bash driver (Scripts/eval/run_dedup_top10_evals.sh):
# DEDUP_EVAL_RESET=1          # wipe prefetch + eval checkpoints
# DEDUP_EVAL_OLLAMA_STOP=1    # ollama stop embedding model between phases
# DEDUP_EVAL_SLEEP_BETWEEN_STEPS=4
# DEDUP_CONDA_ENV=Data        # conda env name for driver
# DEDUP_NO_CONDA=1            # use plain python on PATH instead of conda
