# Byte-compiled / optimized
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
ENV/
env/

# Environment and secrets — never commit `.env` (GEMINI_API_KEY, etc.); use `.env.example` only.
.env
.env.*
!.env.example
# Local git-filter-repo replacement maps (never commit)
replacements.txt

# Jupyter
.ipynb_checkpoints/

# Packaging / build
build/
dist/
*.egg-info/
.eggs/

# Test / type / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
coverage.xml

# OS
.DS_Store
Thumbs.db

# Editor / local tooling
.idea/
.vscode/
.cursor/

# --- This repo: generated or heavy local artifacts (see Scripts/config.py) ---

# Local DB / vector index files (any path)
*.sqlite3
*.sqlite
*.duckdb
*.db
*.db-shm
*.db-wal

# Chroma persistent vector stores (rebuild via embeddings_chromadb / build_chunk_indices)
Data/chroma_db/
Data/chroma_db_sample/
Data/chroma_chunk_*/

# Large source/corpus exports (regenerate via data_extraction_load / chunking)
Data/train*.jsonl
Data/chunks_*.jsonl

# Resume/checkpoint files are local run state, not result artifacts.
Data/**/*.checkpoint.json
Data/**/eval_grid_checkpoint.json

# Generated eval indexes / caches (rebuildable, can be large)
Data/neighbor_index/
Data/neighbor_index_dedup/
Data/**/prefetch/

# Evaluation outputs are intentionally tracked:
#   Data/eval/
#   Data/eval_top5_*/
#   Data/eval_top10/
#   Data/eval_top10_dedup/
#   Data/enhanced_questions/
#   Data/multi_query_questions/
#   Data/ground_truth*.jsonl
#   Data/eval_corpus_manifest*.json

# Optional single-file chunk dump used by the main pipeline (CHUNKS_JSONL)
Data/chunks.jsonl

# Local video (GitHub 100 MB file limit)
*.mp4
*.mov
*.mkv
*.avi

# Heavy binary / model / archive artifacts
*.7z
*.arrow
*.bin
*.ckpt
*.faiss
*.gz
*.joblib
*.onnx
*.parquet
*.pkl
*.ppt
*.pptx
*.pt
*.pth
*.rar
*.safetensors
*.tar
*.tar.gz
*.xz
*.zip

# Logs (if you add file logging under the repo)
*.log

# Committed smoke-test fixture (small; tracked despite patterns above)
!tests/fixture/
!tests/fixture/**

# Webapp (Vite)
webapp/node_modules/
webapp/dist/
webapp/.env
