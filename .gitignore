# --- This repo: generated or heavy local artifacts (see Scripts/config.py) ---

# Local DB / vector index files (any path)
*.sqlite3
*.duckdb

# Chroma persistent vector stores (rebuild via embeddings_chromadb / build_chunk_indices)
Data/chroma_db/
Data/chroma_db_sample/
Data/chroma_chunk_*/

# Large dataset exports (regenerate via data_extraction_load / chunking; GitHub blocks files >100MB)
Data/train.jsonl
Data/train_dedup.jsonl
Data/chunks_*.jsonl

# Grid eval checkpoint + CSV outputs (Scripts/eval/run_grid_eval.py; use git add -f to archive)
Data/eval/

# Top-5 / 1000-q eval pipeline (Scripts/eval/run_top5_eval.py, ground_truth_generate_top5.py)
Data/eval_top5_*/
Data/ground_truth_top5_*.jsonl
Data/eval_corpus_manifest_top5.json

# Ground-truth resume checkpoints (Scripts/eval/ground_truth_generate.py)
Data/*.jsonl.checkpoint.json

# Top-10 four-eval pipeline (Scripts/eval/top10/)
Data/eval_top10/
Data/enhanced_questions/
Data/multi_query_questions/
Data/neighbor_index/
Data/chunk_stats.json

# Optional single-file chunk dump used by the main pipeline (CHUNKS_JSONL)
Data/chunks.jsonl

# Logs (if you add file logging under the repo)
*.log
