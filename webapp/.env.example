# =============================================================================
# Copy to `webapp/.env` for the Vite dev server / production build.
# Never commit `webapp/.env` (gitignored).
#
# GEMINI_API_KEY and all RAG/backend settings live in the PROJECT ROOT `.env`
# (see `/.env.example` at repo root). The browser never sees those keys.
# =============================================================================


# -----------------------------------------------------------------------------
# Frontend — API connection
# -----------------------------------------------------------------------------
# Base URL for FastAPI (no trailing slash).
#   Local API:     http://localhost:8000
#   Vite proxy:    /api   (uses vite.config.ts proxy to :8000)
VITE_API_BASE_URL=http://localhost:8000
